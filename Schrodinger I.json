      "parameters": {
        "jsCode": "// 1. Capturamos y limpiamos el texto igual que antes\nlet textoCrudo = $input.item.json.output || \"La IA no generó respuesta.\";\nlet textoLimpio = String(textoCrudo).replace(/[\\x00-\\x09\\x0B-\\x1F\\x7F]/g, '');\n\n// 2. Partimos el mensaje en bloques de texto.\nlet limite = 1900;\nlet fragmentos = [];\n\nfor (let i = 0; i < textoLimpio.length; i += limite) {\n    fragmentos.push({\n        json: {\n            mensaje_seguro: textoLimpio.substring(i, i + limite)\n        }\n    });\n}\n\nreturn fragmentos;"
